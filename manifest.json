{
    "manifest_version": 3,
    "name": "Developer Home",
    "author": "Rajeshwar Kashyap",
    "version": "1.0.1",
    "version_name": "1.0.1",
    "description": "A customizable new tab page for developers",
    "permissions": [
        "storage",
        "bookmarks",
        "geolocation",
        "notifications",
        "search"
    ],
    "host_permissions": [
        "https://api.github.com/*",
        "https://api.openweathermap.org/*"
    ],
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "icons": {
        "16": "icons/icon16.png",
        "32": "icons/icon32.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    }
}
