{
    "manifest_version": 3,
    "name": "Developer Workspace",
    "author": "Rajeshwar Kashyap",
    "version": "1.0",
    "description": "A developer workspace for Chrome",
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "permissions": [
        "storage",
        "notifications",
        "geolocation",
        "search",
        "bookmarks",
        "tabs"
    ],
    "icons": {
        "16": "icons/icon-48x48.png",
        "48": "icons/icon-72x72.png",
        "72": "icons/icon-96x96.png",
        "128": "icons/icon-128x128.png",
        "192": "icons/icon-192x192.png",
        "256": "icons/icon-256x256.png",
        "512": "icons/icon-512x512.png"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "bookmark-importer.js"
            ]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}
